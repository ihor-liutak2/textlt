{
  "version": 1,
  "name": "TextLT AI Models Registry",
  "default_backend": "llama_cpp",
  "backends": [
    {
      "id": "llama_cpp",
      "title": "llama.cpp portable backend",
      "type": "portable",
      "runtime": {
        "download_page": "https://github.com/ggml-org/llama.cpp/releases",
        "binary_name": "llama-cli",
        "server_binary_name": "llama-server",
        "runtime_assets": [
          {
            "platform": "linux",
            "arch": "x64",
            "backend": "cpu",
            "asset_pattern": "llama-*-bin-ubuntu-x64.tar.gz",
            "recommended": true
          },
          {
            "platform": "linux",
            "arch": "x64",
            "backend": "vulkan",
            "asset_pattern": "llama-*-bin-ubuntu-vulkan-x64.tar.gz",
            "recommended": false
          },
          {
            "platform": "windows",
            "arch": "x64",
            "backend": "cpu",
            "asset_pattern": "llama-*-bin-win-cpu-x64.zip",
            "recommended": true
          },
          {
            "platform": "windows",
            "arch": "x64",
            "backend": "cuda",
            "asset_pattern": "llama-*-bin-win-cuda-12.4-x64.zip",
            "recommended": false
          },
          {
            "platform": "windows",
            "arch": "x64",
            "backend": "cuda",
            "asset_pattern": "llama-*-bin-win-cuda-13.3-x64.zip",
            "recommended": false
          }
        ]
      }
    }
  ],
  "defaults": {
    "text_model": "gemma-3-1b-it-q4",
    "formula_model": "gemma-3-270m-it-q4"
  },
  "models": [
    {
      "id": "gemma-3-1b-it-q4",
      "title": "Gemma 3 1B Instruct Q4",
      "backend": "llama_cpp",
      "format": "gguf",
      "purpose": "text",
      "recommended": true,
      "model_url": "https://huggingface.co/unsloth/gemma-3-1b-it-GGUF/resolve/main/gemma-3-1b-it-Q4_K_M.gguf",
      "filename": "gemma-3-1b-it-q4.gguf",
      "description": "Default small multilingual model for translation, explanation, grammar fixing, summarization and text improvement."
    },
    {
      "id": "gemma-3-270m-it-q4",
      "title": "Gemma 3 270M Instruct Q4",
      "backend": "llama_cpp",
      "format": "gguf",
      "purpose": "formula",
      "recommended": true,
      "model_url": "https://huggingface.co/unsloth/gemma-3-270m-it-GGUF/resolve/main/gemma-3-270m-it-Q4_0.gguf",
      "filename": "gemma-3-270m-it-q4.gguf",
      "description": "Small model for converting text-written formulas into calculator expressions. The model should not calculate results."
    }
  ],
  "actions": [
    {
      "id": "translate",
      "title": "Translate",
      "model_purpose": "text"
    },
    {
      "id": "improve",
      "title": "Improve text",
      "model_purpose": "text"
    },
    {
      "id": "summarize",
      "title": "Summarize",
      "model_purpose": "text"
    },
    {
      "id": "explain",
      "title": "Explain",
      "model_purpose": "text"
    },
    {
      "id": "fix_grammar",
      "title": "Fix grammar",
      "model_purpose": "text"
    },
    {
      "id": "formula_to_expression",
      "title": "Formula to expression",
      "model_purpose": "formula"
    }
  ]
}